{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/company-os/runtime/cron",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/company/loop/cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/company/ideas/cron",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/opportunity-radar",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/alerts/cron",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/company/digest/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/reports/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/company/learning/cron",
      "schedule": "0 7 * * 0"
    }
  ]
}
