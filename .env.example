# Core AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Model used for PDF/image government-document analysis through the Responses API.
OPENAI_DOCUMENT_MODEL=gpt-4.1-mini

# Durable persistence (server-side writes use the service-role key only)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Governance / auth
AUTH_ENABLED=true
API_SECRET_KEY=
CRON_SECRET=
# Private owner workspace. Keep both values server-side and use independent,
# high-entropy secrets in production.
ORVANTA_PERSONAL_MODE=true
ORVANTA_OWNER_ACCESS_KEY=
ORVANTA_OWNER_COOKIE_SECRET=
ORVANTA_COOKIE_SECURE=true
# Trusted owner devices keep the refresh session for this many days (30-365).
ORVANTA_OWNER_SESSION_DAYS=180

# Tenant and core readiness gates
ORVANTA_TENANT_ID=golden-star
ORVANTA_MULTI_TENANT=false
ORVANTA_CORE_SCHEMA_READY=false
ORVANTA_MIGRATIONS_BASELINED=false
ORVANTA_RLS_READY=false
ORVANTA_RLS_TESTED=false
ORVANTA_WORKFLOW_RUNTIME_ENABLED=true
ORVANTA_OUTBOX_ENABLED=false
ORVANTA_RECONCILIATION_REQUIRED=true
ORVANTA_WATCHDOG_ENABLED=false
ORVANTA_FAILED_WRITE_WORKER_ENABLED=false
ORVANTA_CAPABILITY_REGISTRY_READY=false
ORVANTA_ACCOUNTING_CONTROLS_READY=false
ORVANTA_E2E_VERIFIED=false
ORVANTA_BACKUP_RESTORE_VERIFIED=false

# Optional signed event delivery
ORVANTA_WEBHOOK_URL=
ORVANTA_WEBHOOK_SECRET=

# Google Workspace integrations
# Keep the kill switch false until OAuth credentials are configured and tested.
GOOGLE_INTEGRATIONS_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional defaults
GOOGLE_GMAIL_SENDER=
GOOGLE_DEFAULT_REVIEW_EMAIL=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_NAME=Orvanta Action Queue
GOOGLE_SHEETS_TAB=Actions
GOOGLE_DRIVE_FOLDER_ID=

# Local OAuth helper only
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
GOOGLE_OAUTH_PORT=53682

# Shared rate limiting across serverless instances (optional).
# Without these, limits are per-instance only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alpaca Paper Trading (server-only; never prefix secrets with NEXT_PUBLIC_)
# Orvanta accepts Alpaca's APCA_API_KEY_ID / APCA_API_SECRET_KEY aliases too.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_SCALP_SYMBOL=SPY
ALPACA_DATA_FEED=iex

# Real-money trading stays locked unless all three gates are explicitly set.
ALPACA_LIVE=false
TRADING_LIVE_ENABLED=false
TRADING_LIVE_ACK=
