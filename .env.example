# Core AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Model used for PDF/image government-document analysis through the Responses API.
OPENAI_DOCUMENT_MODEL=gpt-4.1-mini

# Durable persistence (server-side writes use the service-role key only)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Governance / auth
AUTH_ENABLED=true
API_SECRET_KEY=
CRON_SECRET=
# Trusted owner devices keep the refresh session for this many days (30-365).
ORVANTA_OWNER_SESSION_DAYS=180

# Tenant and core readiness gates
ORVANTA_TENANT_ID=golden-star
ORVANTA_MULTI_TENANT=true
ORVANTA_CORE_SCHEMA_READY=true
ORVANTA_RLS_READY=true
ORVANTA_WORKFLOW_RUNTIME_ENABLED=true
ORVANTA_OUTBOX_ENABLED=true
ORVANTA_RECONCILIATION_REQUIRED=true

# Optional signed event delivery
ORVANTA_WEBHOOK_URL=
ORVANTA_WEBHOOK_SECRET=

# Google Workspace integrations
# Keep the kill switch false until OAuth credentials are configured and tested.
GOOGLE_INTEGRATIONS_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional defaults
GOOGLE_GMAIL_SENDER=
GOOGLE_DEFAULT_REVIEW_EMAIL=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_NAME=Orvanta Action Queue
GOOGLE_SHEETS_TAB=Actions
GOOGLE_DRIVE_FOLDER_ID=

# Local OAuth helper only
GOOGLE_REDIRECT_URI=http://127.0.0.1:53682/oauth2callback
GOOGLE_OAUTH_PORT=53682
